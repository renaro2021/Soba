{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "name": "Soba - A browser extension so your YouTube Comment Section will be a sidebar",
  "author": "renaro076",
  "description": "Watch YouTube Videos with your Comment Section being a sidebar",
  "version": "1.0",
  "manifest_version": 3,
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["sidebarcommentsLoader.js"],
      "css": ["sidebarLayout.css"]
    }
  ],
  "host_permissions": [
    "https://www.youtube.com/watch*"
  ],
  "permissions": [
    "scripting",
    "webNavigation",
    "storage"
  ],
  "background": {
    "service_worker": "pageactivityListener.js"
  },
  "icons": {
    "128": "logo.png"
  }
}
